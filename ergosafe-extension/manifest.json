{
  "manifest_version": 3,
  "name": "ErgoSafe: AI Safety Layer",
  "version": "1.0",
  "description": "AI-driven OHS Stewardship and Fatigue-Gate for Remote Professionals.",
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://ergo-safe-reborn.vercel.app/*",
    "https://*.vercel.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://ergo-safe-reborn.vercel.app https://*.vercel.app;"
  },
  "content_scripts": [
    {
      "matches": [
        "*://mail.google.com/*",
        "*://teams.microsoft.com/*",
        "*://outlook.office.com/*",
        "*://*.slack.com/*"
      ],
      "css": ["src/content/content.css"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
